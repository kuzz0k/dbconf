version: '3.8'

services:
  db:
    image: postgres:{{ postgres_version | default('15-alpine') }}
    container_name: postgres_db
    restart: always
    environment:
      POSTGRES_USER: {{ db_user }}
      POSTGRES_PASSWORD: {{ db_password }}
      POSTGRES_DB: {{ db_name }}
    ports:
      - "{{ db_port | default(5432) }}:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ db_user }} -d {{ db_name }}"]
      interval: 10s
      timeout: 5s
      retries: 5

  pgadmin:
    image: dpage/pgadmin4
    container_name: pgadmin_panel
    restart: always
    environment:
      PGADMIN_DEFAULT_EMAIL: {{ pgadmin_email | default('admin@admin.com') }}
      PGADMIN_DEFAULT_PASSWORD: {{ pgadmin_password | default('admin_pass') }}
    ports:
      - "{{ pgadmin_port | default(8080) }}:80"
    depends_on:
      db:
        condition: service_healthy

volumes:
  postgres_data: